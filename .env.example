# OpenAI (required for embeddings + agent fallback)
OPENAI_API_KEY=sk-your-key-here

# Use GitClaw sidecar for agent execution (slower). Default: OpenAI + git-native SOUL.md prompts
USE_GITAGENT_RUNNER=false

# GitHub (optional, for private repos)
GITHUB_TOKEN=

# GitClaw agent runner
AGENT_RUNNER_URL=http://localhost:4000
AGENTS_ROOT=./agents

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Repo storage
REPOS_CACHE_DIR=./data/repos
VECTORSTORE_DIR=./data/vectorstores
